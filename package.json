{
  "name": "my-app",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.5.2",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "init-views": "npx tsx scripts/init-view-orders.ts",
    "seed": "npx tsx scripts/seed-data.ts",
    "test": "dotenv -e .env.test -- prisma db push && vitest run",
    "test:ci": "vitest run",
    "test:watch": "dotenv -e .env.test -- vitest",
    "inngest:dev": "npx inngest-cli@latest dev -u http://localhost:3000/api/inngest",
    "test:integration": "dotenv -e .env.test -o -- vitest run tests/integration --no-file-parallelism",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
