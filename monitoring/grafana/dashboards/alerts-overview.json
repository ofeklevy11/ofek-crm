{
  "uid": "alerts-overview",
  "title": "Alerts Overview",
  "tags": ["bizlycrm", "alerts"],
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Active Alerts",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "count(ALERTS{alertstate=\"firing\"}) or vector(0)",
          "legendFormat": "Firing"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 1, "color": "yellow" },
              { "value": 3, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Pending Alerts",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 0 },
      "targets": [
        {
          "expr": "count(ALERTS{alertstate=\"pending\"}) or vector(0)",
          "legendFormat": "Pending"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 1, "color": "yellow" }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Services Status",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 0 },
      "targets": [
        {
          "expr": "count(up == 1)",
          "legendFormat": "Healthy"
        },
        {
          "expr": "count(up == 0)",
          "legendFormat": "Down"
        }
      ]
    },
    {
      "id": 4,
      "title": "Active Alerts Table",
      "type": "table",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "ALERTS{alertstate=\"firing\"}",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "includeByName": {
              "alertname": true,
              "severity": true,
              "category": true,
              "Value": true
            }
          }
        }
      ]
    },
    {
      "id": 5,
      "title": "Alert History (Firing)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 14 },
      "targets": [
        {
          "expr": "ALERTS{alertstate=\"firing\"}",
          "legendFormat": "{{ alertname }} ({{ severity }})"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "right" }
      }
    },
    {
      "id": 6,
      "title": "Alerts by Severity",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 22 },
      "targets": [
        {
          "expr": "count(ALERTS{alertstate=\"firing\"}) by (severity) or vector(0)",
          "legendFormat": "{{ severity }}"
        }
      ]
    },
    {
      "id": 7,
      "title": "Alerts by Category",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 22 },
      "targets": [
        {
          "expr": "count(ALERTS{alertstate=\"firing\"}) by (category) or vector(0)",
          "legendFormat": "{{ category }}"
        }
      ]
    }
  ],
  "schemaVersion": 39
}
