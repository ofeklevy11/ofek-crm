{
  "uid": "crm-overview",
  "title": "CRM Overview",
  "tags": ["bizlycrm", "overview"],
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-3h", "to": "now" },
  "panels": [
    {
      "id": 100,
      "type": "row",
      "title": "Health Status",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "id": 1,
      "title": "App",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "targets": [
        {
          "expr": "up{job=\"nextjs-app\"}",
          "legendFormat": "App"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ]
        }
      },
      "options": { "colorMode": "background", "textMode": "value" }
    },
    {
      "id": 2,
      "title": "PostgreSQL",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "targets": [
        {
          "expr": "pg_up",
          "legendFormat": "PG"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ]
        }
      },
      "options": { "colorMode": "background", "textMode": "value" }
    },
    {
      "id": 3,
      "title": "Redis",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "targets": [
        {
          "expr": "redis_up",
          "legendFormat": "Redis"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ]
        }
      },
      "options": { "colorMode": "background", "textMode": "value" }
    },
    {
      "id": 4,
      "title": "Requests/s",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "targets": [
        {
          "expr": "rate(nginx_http_requests_total[5m])",
          "legendFormat": "req/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 100, "color": "yellow" },
              { "value": 500, "color": "red" }
            ]
          }
        }
      },
      "options": { "colorMode": "background", "textMode": "value" }
    },
    {
      "id": 5,
      "title": "Active Alerts",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "targets": [
        {
          "expr": "count(ALERTS{alertstate=\"firing\"}) or vector(0)",
          "legendFormat": "Firing"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 1, "color": "orange" },
              { "value": 3, "color": "red" }
            ]
          }
        }
      },
      "options": { "colorMode": "background", "textMode": "value" }
    },
    {
      "id": 6,
      "title": "SSL Cert Expiry",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "targets": [
        {
          "expr": "(probe_ssl_earliest_cert_expiry{instance=\"bizlycrm.com:443\"} - time()) / 86400",
          "legendFormat": "Days"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "d",
          "decimals": 0,
          "thresholds": {
            "steps": [
              { "value": 0, "color": "red" },
              { "value": 7, "color": "orange" },
              { "value": 21, "color": "green" }
            ]
          }
        }
      },
      "options": { "colorMode": "background", "textMode": "value" }
    },

    {
      "id": 101,
      "type": "row",
      "title": "Traffic (Nginx)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false
    },
    {
      "id": 7,
      "title": "Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 6 },
      "targets": [
        {
          "expr": "rate(nginx_http_requests_total[5m])",
          "legendFormat": "Requests/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "fillOpacity": 15, "lineWidth": 2 }
        }
      }
    },
    {
      "id": 8,
      "title": "Nginx Connections",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 6 },
      "targets": [
        {
          "expr": "nginx_connections_active",
          "legendFormat": "Active"
        },
        {
          "expr": "nginx_connections_reading",
          "legendFormat": "Reading"
        },
        {
          "expr": "nginx_connections_writing",
          "legendFormat": "Writing"
        },
        {
          "expr": "nginx_connections_waiting",
          "legendFormat": "Waiting"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 10, "lineWidth": 2 }
        }
      }
    },

    {
      "id": 102,
      "type": "row",
      "title": "Container Resources (Docker)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 },
      "collapsed": false
    },
    {
      "id": 9,
      "title": "Container CPU Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{name=~\"crm-.+\", image!=\"\"}[5m])) by (name) * 100",
          "legendFormat": "{{ name }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": { "fillOpacity": 10, "lineWidth": 1 }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "sortBy": "Mean", "sortDesc": true }
      }
    },
    {
      "id": 10,
      "title": "Container Memory Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "targets": [
        {
          "expr": "container_memory_usage_bytes{name=~\"crm-.+\", image!=\"\"} - container_memory_cache{name=~\"crm-.+\", image!=\"\"}",
          "legendFormat": "{{ name }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "fillOpacity": 10, "lineWidth": 1 }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "sortBy": "Mean", "sortDesc": true }
      }
    },

    {
      "id": 103,
      "type": "row",
      "title": "System Resources",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "collapsed": false
    },
    {
      "id": 11,
      "title": "CPU",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 23 },
      "targets": [
        {
          "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "CPU %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0, "max": 100,
          "thresholds": {
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 70, "color": "yellow" },
              { "value": 85, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 12,
      "title": "Memory",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 23 },
      "targets": [
        {
          "expr": "(1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) * 100",
          "legendFormat": "RAM %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0, "max": 100,
          "thresholds": {
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 80, "color": "yellow" },
              { "value": 90, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 13,
      "title": "Disk",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 23 },
      "targets": [
        {
          "expr": "(1 - node_filesystem_avail_bytes{mountpoint=\"/\"} / node_filesystem_size_bytes{mountpoint=\"/\"}) * 100",
          "legendFormat": "Disk %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0, "max": 100,
          "thresholds": {
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 75, "color": "yellow" },
              { "value": 85, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 14,
      "title": "Uptime",
      "type": "stat",
      "gridPos": { "h": 3, "w": 6, "x": 18, "y": 23 },
      "targets": [
        {
          "expr": "time() - node_boot_time_seconds",
          "legendFormat": "Uptime"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "dtdurations" }
      },
      "options": { "textMode": "value" }
    },
    {
      "id": 15,
      "title": "Disk Free",
      "type": "stat",
      "gridPos": { "h": 3, "w": 6, "x": 18, "y": 26 },
      "targets": [
        {
          "expr": "node_filesystem_avail_bytes{mountpoint=\"/\"}",
          "legendFormat": "Available"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes" }
      },
      "options": { "textMode": "value" }
    },
    {
      "id": 16,
      "title": "CPU Over Time",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 29 },
      "targets": [
        {
          "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "CPU %"
        },
        {
          "expr": "node_load1 / count(count(node_cpu_seconds_total{mode=\"idle\"}) by (cpu)) * 100",
          "legendFormat": "Load (normalized) %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "custom": { "fillOpacity": 15, "lineWidth": 2 }
        }
      }
    },
    {
      "id": 17,
      "title": "Memory Over Time",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 29 },
      "targets": [
        {
          "expr": "node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes",
          "legendFormat": "Used"
        },
        {
          "expr": "node_memory_MemTotal_bytes",
          "legendFormat": "Total"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "fillOpacity": 15, "lineWidth": 2 }
        }
      }
    },

    {
      "id": 104,
      "type": "row",
      "title": "Database & Cache",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 36 },
      "collapsed": false
    },
    {
      "id": 18,
      "title": "DB Active Connections",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 37 },
      "targets": [
        {
          "expr": "pg_stat_activity_count",
          "legendFormat": "Active"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 7, "color": "yellow" },
              { "value": 9, "color": "red" }
            ]
          }
        }
      },
      "options": { "colorMode": "background", "textMode": "value" }
    },
    {
      "id": 19,
      "title": "Redis Memory",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 37 },
      "targets": [
        {
          "expr": "redis_memory_used_bytes",
          "legendFormat": "Used"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes" }
      },
      "options": { "colorMode": "background", "textMode": "value" }
    },
    {
      "id": 20,
      "title": "Redis Hit Rate",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 37 },
      "targets": [
        {
          "expr": "redis_keyspace_hits_total / (redis_keyspace_hits_total + redis_keyspace_misses_total) * 100",
          "legendFormat": "Hit Rate"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "thresholds": {
            "steps": [
              { "value": 0, "color": "red" },
              { "value": 50, "color": "yellow" },
              { "value": 80, "color": "green" }
            ]
          }
        }
      },
      "options": { "colorMode": "background", "textMode": "value" }
    },
    {
      "id": 21,
      "title": "Redis Clients",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 37 },
      "targets": [
        {
          "expr": "redis_connected_clients",
          "legendFormat": "Clients"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 20, "color": "yellow" },
              { "value": 50, "color": "red" }
            ]
          }
        }
      },
      "options": { "colorMode": "background", "textMode": "value" }
    },
    {
      "id": 22,
      "title": "Network I/O",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 37 },
      "targets": [
        {
          "expr": "rate(node_network_receive_bytes_total{device!~\"lo|veth.*|br-.*|docker.*\"}[5m])",
          "legendFormat": "In"
        },
        {
          "expr": "rate(node_network_transmit_bytes_total{device!~\"lo|veth.*|br-.*|docker.*\"}[5m])",
          "legendFormat": "Out"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "Bps" }
      },
      "options": { "textMode": "value_and_name" }
    },
    {
      "id": 23,
      "title": "Load Avg",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 37 },
      "targets": [
        {
          "expr": "node_load1",
          "legendFormat": "1m"
        },
        {
          "expr": "node_load5",
          "legendFormat": "5m"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "decimals": 2,
          "thresholds": {
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 2, "color": "yellow" },
              { "value": 4, "color": "red" }
            ]
          }
        }
      },
      "options": { "textMode": "value_and_name" }
    },
    {
      "id": 24,
      "title": "DB Connections & Transactions",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 41 },
      "targets": [
        {
          "expr": "pg_stat_activity_count",
          "legendFormat": "Connections"
        },
        {
          "expr": "rate(pg_stat_database_xact_commit{datname!=\"\"}[5m])",
          "legendFormat": "Commits/s {{ datname }}"
        },
        {
          "expr": "rate(pg_stat_database_xact_rollback{datname!=\"\"}[5m])",
          "legendFormat": "Rollbacks/s {{ datname }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 10, "lineWidth": 2 }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right" }
      }
    },
    {
      "id": 25,
      "title": "Redis Memory & Clients",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 41 },
      "targets": [
        {
          "expr": "redis_memory_used_bytes",
          "legendFormat": "Memory Used"
        },
        {
          "expr": "redis_connected_clients",
          "legendFormat": "Clients"
        }
      ],
      "fieldConfig": {
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Memory Used" },
            "properties": [{ "id": "unit", "value": "bytes" }, { "id": "custom.axisPlacement", "value": "left" }]
          },
          {
            "matcher": { "id": "byName", "options": "Clients" },
            "properties": [{ "id": "custom.axisPlacement", "value": "right" }]
          }
        ],
        "defaults": {
          "custom": { "fillOpacity": 10, "lineWidth": 2 }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right" }
      }
    }
  ],
  "schemaVersion": 39
}
