# =============================================================================
# Bizly CRM — Development Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# Never commit .env — only .env.example is tracked in git.
# =============================================================================

# === DATABASE ===
# For local dev with Docker: docker compose up postgres
POSTGRES_USER="crm_user"
POSTGRES_PASSWORD="localdevpassword"
POSTGRES_DB="ofek_crm"
DATABASE_URL="postgresql://crm_user:localdevpassword@localhost:5432/ofek_crm"

# === REDIS ===
# For local dev with Docker: docker compose up redis
REDIS_PASSWORD="localdevpassword"
REDIS_URL="redis://localhost:6379"

# === APP ===
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# GENERATE_WITH: openssl rand -hex 32 (must be at least 32 characters)
SESSION_SECRET=""
# GENERATE_WITH: openssl rand -hex 16
CRON_SECRET=""
NURTURE_WEBHOOK_SECRET=""

# === UPLOADTHING (file uploads) ===
# Get from: https://uploadthing.com/dashboard
UPLOADTHING_TOKEN=""

# === OPENROUTER (AI) ===
# Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY=""

# === PDF GENERATION ===
# Get from: https://dashboard.pdfmonkey.io
PDFMONKEY_TEMPLATE_ID=""
PDFMONKEY_API_KEY=""

# === EMAIL ===
# Get from: https://resend.com/api-keys
RESEND_API_KEY=""

# === WHATSAPP ===
# Get from: https://developers.facebook.com
WHATSAPP_APP_ID=""
NEXT_PUBLIC_WHATSAPP_APP_ID=""
WHATSAPP_APP_SECRET=""
# GENERATE_WITH: openssl rand -hex 32 (must be exactly 64 hex characters)
WHATSAPP_TOKEN_ENCRYPTION_KEY=""
NEXT_PUBLIC_WHATSAPP_CONFIG_ID=""
WHATSAPP_VERIFY_TOKEN=""
WHATSAPP_ACCESS_TOKEN=""

# === INNGEST (background jobs) ===
# Leave empty for local dev (uses dev server)
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""

# === GOOGLE (Calendar + Drive) ===
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# GENERATE_WITH: openssl rand -hex 32 (must be exactly 64 hex characters)
GOOGLE_TOKEN_ENCRYPTION_KEY=""

# === MONITORING (only needed for production) ===
# TELEGRAM_BOT_TOKEN=""
# TELEGRAM_CHAT_ID=""
# WEBHOOK_SECRET=""
# GF_SECURITY_ADMIN_PASSWORD=""
