generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   Int           @id @default(autoincrement())
  name                 String
  email                String        @unique
  passwordHash         String
  role                 String        @default("basic")
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  allowedWriteTableIds Int[]         @default([])
  auditLogs            AuditLog[]
  records              Record[]      @relation("CreatedBy")
  tables               TableMeta[]   @relation("CreatedBy")
  transactions         Transaction[]
  notifications        Notification[]
  automationRules      AutomationRule[]
  sentMessages         Message[]     @relation("SentMessages")
  receivedMessages     Message[]     @relation("ReceivedMessages")
  createdGroups        Group[]       @relation("CreatedGroups")
  groupMemberships     GroupMember[]
}

model Message {
  id         Int      @id @default(autoincrement())
  content    String
  senderId   Int
  receiverId Int?
  groupId    Int?
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())

  sender     User     @relation("SentMessages", fields: [senderId], references: [id])
  receiver   User?    @relation("ReceivedMessages", fields: [receiverId], references: [id])
  group      Group?   @relation(fields: [groupId], references: [id])
}

model Group {
  id        Int           @id @default(autoincrement())
  name      String
  imageUrl  String?
  creatorId Int
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  creator   User          @relation("CreatedGroups", fields: [creatorId], references: [id])
  members   GroupMember[]
  messages  Message[]
}

model GroupMember {
  id        Int      @id @default(autoincrement())
  groupId   Int
  userId    Int
  joinedAt  DateTime @default(now())
  lastReadAt DateTime @default(now())
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
}

model AutomationRule {
  id            Int      @id @default(autoincrement())
  name          String
  triggerType   String   // 'MANUAL', 'TASK_STATUS_CHANGE', 'RECORD_CREATE'
  triggerConfig Json?    // Configuration for the trigger (e.g., fromStatus, toStatus)
  actionType    String   // 'SEND_NOTIFICATION'
  actionConfig  Json?    // Configuration for the action (e.g., recipientId, message)
  isActive      Boolean  @default(true)
  createdBy     Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  creator       User     @relation(fields: [createdBy], references: [id])
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  title     String
  message   String?
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TableMeta {
  id         Int      @id @default(autoincrement())
  name       String
  slug       String   @unique
  createdBy  Int
  schemaJson Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  records    Record[] @relation("TableRecords")
  creator    User     @relation("CreatedBy", fields: [createdBy], references: [id])
  categoryId Int?
  category   TableCategory? @relation(fields: [categoryId], references: [id])
  views      View[]   @relation("TableViews")
}

model TableCategory {
  id        Int         @id @default(autoincrement())
  name      String
  tables    TableMeta[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model View {
  id         Int       @id @default(autoincrement())
  tableId    Int
  name       String
  slug       String
  config     Json
  isEnabled  Boolean   @default(true)
  order      Int       @default(0)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  table      TableMeta @relation("TableViews", fields: [tableId], references: [id], onDelete: Cascade)

  @@unique([tableId, slug])
  @@index([tableId])
  @@index([tableId, order])
}


model Record {
  id          Int          @id @default(autoincrement())
  tableId     Int
  data        Json
  createdBy   Int?
  updatedBy   Int?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  attachments Attachment[]
  auditLogs   AuditLog[]
  creator     User?        @relation("CreatedBy", fields: [createdBy], references: [id])
  table       TableMeta    @relation("TableRecords", fields: [tableId], references: [id])
}

model Attachment {
  id         Int      @id @default(autoincrement())
  recordId   Int
  filename   String
  url        String
  size       Int
  uploadedBy Int
  uploadedAt DateTime @default(now())
  record     Record   @relation(fields: [recordId], references: [id])
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  recordId  Int?
  userId    Int?
  action    String
  diffJson  Json?
  timestamp DateTime @default(now())
  record    Record?  @relation(fields: [recordId], references: [id])
  user      User?    @relation(fields: [userId], references: [id])
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  status      String
  assignee    String?
  priority    String?
  dueDate     DateTime?
  tags        String[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model CalendarEvent {
  id          String   @id @default(cuid())
  title       String
  description String?
  startTime   DateTime
  endTime     DateTime
  color       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Client {
  id              Int                     @id @default(autoincrement())
  name            String
  email           String?
  phone           String?
  company         String?
  notes           String?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  oneTimePayments OneTimePayment[]
  paymentMethods  PaymentMethodInternal[]
  retainers       Retainer[]
  transactions    Transaction[]
}

model Retainer {
  id          Int       @id @default(autoincrement())
  clientId    Int
  title       String
  amount      Decimal   @db.Decimal(10, 2)
  frequency   String
  startDate   DateTime
  nextDueDate DateTime?
  status      String
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  client      Client    @relation(fields: [clientId], references: [id])
}

model OneTimePayment {
  id        Int       @id @default(autoincrement())
  clientId  Int
  title     String
  amount    Decimal   @db.Decimal(10, 2)
  dueDate   DateTime
  paidDate  DateTime?
  status    String
  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  client    Client    @relation(fields: [clientId], references: [id])
}

model Transaction {
  id          Int       @id @default(autoincrement())
  clientId    Int
  relatedType String
  relatedId   Int
  amount      Decimal   @db.Decimal(10, 2)
  attemptedBy Int?
  attemptDate DateTime  @default(now())
  paidDate    DateTime?
  status      String
  receiptFile String?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User?     @relation(fields: [attemptedBy], references: [id])
  client      Client    @relation(fields: [clientId], references: [id])
}

model PaymentMethodInternal {
  id         Int      @id @default(autoincrement())
  clientId   Int
  methodType String
  details    String?
  note       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  client     Client   @relation(fields: [clientId], references: [id])
}
