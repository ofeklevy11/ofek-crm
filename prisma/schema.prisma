generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Company {
  id        Int      @id @default(autoincrement())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Business settings for quotes
  businessType    String?   // "exempt" (עוסק פטור), "licensed" (עוסק מורשה), "ltd" (חברה בע"מ)
  taxId           String?   // ח.פ / מספר עוסק
  businessAddress String?   // כתובת העסק
  businessWebsite String?   // קישור לאתר (אופציונלי)
  businessEmail   String?   // אימייל עסקי (אופציונלי)
  
  users               User[]
  tables              TableMeta[]
  records             Record[]
  tasks               Task[]
  clients             Client[]
  automationRules     AutomationRule[]
  calendarEvents      CalendarEvent[]
  notifications       Notification[]
  messages            Message[]
  groups              Group[]
  analyticsViews      AnalyticsView[]
  viewFolders         ViewFolder[]
  tableCategories     TableCategory[]

  workflows           Workflow[]
  workflowInstances   WorkflowInstance[]
  products            Product[]
  quotes              Quote[]
  tickets             Ticket[]
  slaPolicies         SlaPolicy[]
  slaBreaches         SlaBreach[]
  
  folders             Folder[]
  files               File[]
  goals               Goal[]
  financeRecords      FinanceRecord[]
  fixedExpenses       FixedExpense[]
  financeSyncRules    FinanceSyncRule[]
  taskSheets          TaskSheet[]
  
  // Workers Module
  departments         Department[]
  workers             Worker[]
  onboardingPaths     OnboardingPath[]
  workerTasks         WorkerTask[]

  // Nurture Hub
  nurtureLists        NurtureList[]
}

model User {
  companyId            Int
  id                   Int           @id @default(autoincrement())
  name                 String
  email                String        @unique
  passwordHash         String
  role                 String        @default("basic")
  permissions          Json?         @default("{}")
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  allowedWriteTableIds Int[]         @default([])
  tablePermissions     Json?         @default("{}") // { [tableId]: "read" | "write" }
  auditLogs            AuditLog[]
  records              Record[]      @relation("CreatedBy")
  tables               TableMeta[]   @relation("CreatedBy")
  transactions         Transaction[]
  notifications        Notification[]
  automationRules      AutomationRule[]
  sentMessages         Message[]     @relation("SentMessages")
  receivedMessages     Message[]     @relation("ReceivedMessages")
  createdGroups        Group[]       @relation("CreatedGroups")
  groupMemberships     GroupMember[]
  assignedTasks        Task[]        @relation("TaskAssignee")
  createdInstances     WorkflowInstance[] @relation("InstanceCreator")
  assignedInstances    WorkflowInstance[] @relation("InstanceAssignee")
  createdTickets       Ticket[]           @relation("TicketCreator")
  assignedTickets      Ticket[]           @relation("TicketAssignee")
  
  assignedTaskSheets   TaskSheet[]   @relation("TaskSheetAssignee")
  createdTaskSheets    TaskSheet[]   @relation("TaskSheetCreator")
  
  company              Company       @relation(fields: [companyId], references: [id])
  ticketComments       TicketComment[]
  ticketActivityLogs   TicketActivityLog[]
  
  @@index([companyId])
}

model Message {
  id         Int      @id @default(autoincrement())
  companyId  Int
  content    String
  senderId   Int
  receiverId Int?
  groupId    Int?
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())

  sender     User     @relation("SentMessages", fields: [senderId], references: [id])
  receiver   User?    @relation("ReceivedMessages", fields: [receiverId], references: [id])
  group      Group?   @relation(fields: [groupId], references: [id])
  company    Company  @relation(fields: [companyId], references: [id])
  
  @@index([companyId])
  @@index([senderId, receiverId, createdAt(sort: Desc)]) // For DM queries
  @@index([groupId, createdAt(sort: Desc)])              // For group message queries
  @@index([receiverId, read])                            // For unread counts
}

model Group {
  id        Int           @id @default(autoincrement())
  companyId Int
  name      String
  imageUrl  String?
  creatorId Int
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  creator   User          @relation("CreatedGroups", fields: [creatorId], references: [id])
  members   GroupMember[]
  messages  Message[]
  company   Company       @relation(fields: [companyId], references: [id])
  
  @@index([companyId])
}

model GroupMember {
  id        Int      @id @default(autoincrement())
  groupId   Int
  userId    Int
  joinedAt  DateTime @default(now())
  lastReadAt DateTime @default(now())
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
}

model AutomationRule {
  id            Int      @id @default(autoincrement())
  companyId     Int
  name          String
  triggerType   String   // 'MANUAL', 'TASK_STATUS_CHANGE', 'RECORD_CREATE', 'MULTI_EVENT_DURATION'
  triggerConfig Json?    // Configuration for the trigger (e.g., fromStatus, toStatus)
  actionType    String   // 'SEND_NOTIFICATION', 'CALCULATE_DURATION', 'CALCULATE_MULTI_EVENT_DURATION'
  actionConfig  Json?    // Configuration for the action (e.g., recipientId, message)
  isActive      Boolean  @default(true)
  createdBy     Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  creator       User     @relation(fields: [createdBy], references: [id])
  
  // Relation to the new time tracking tables
  statusDurations StatusDuration[]
  multiEventDurations MultiEventDuration[]

  // Analytics View Configuration
  analyticsOrder Int?     @default(0)
  analyticsColor String?  @default("bg-white") // Stores Tailwind class or color key
  
  folderId      Int?
  folder        ViewFolder? @relation(fields: [folderId], references: [id])
  company       Company     @relation(fields: [companyId], references: [id])
  
  @@index([companyId])
  @@index([companyId, isActive, triggerType]) // For filtering active rules by trigger type
}

model Notification {
  id        Int      @id @default(autoincrement())
  companyId Int
  userId    Int
  title     String
  message   String?
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  company   Company  @relation(fields: [companyId], references: [id])
  
  @@index([companyId])
  @@index([userId, read, createdAt(sort: Desc)]) // For user's unread notifications
}

model TableMeta {
  id         Int      @id @default(autoincrement())
  companyId  Int
  name       String
  slug       String   @unique
  createdBy  Int
  schemaJson Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  records    Record[] @relation("TableRecords")
  creator    User     @relation("CreatedBy", fields: [createdBy], references: [id])
  categoryId Int?
  category   TableCategory? @relation(fields: [categoryId], references: [id])
  order      Int            @default(0)
  views      View[]   @relation("TableViews")
  company    Company  @relation(fields: [companyId], references: [id])
  
  @@index([companyId])
}

model TableCategory {
  id        Int         @id @default(autoincrement())
  companyId Int
  name      String
  tables    TableMeta[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  company   Company     @relation(fields: [companyId], references: [id])
  
  @@index([companyId])
}

model View {
  id         Int       @id @default(autoincrement())
  tableId    Int
  name       String
  slug       String
  config     Json
  isEnabled  Boolean   @default(true)
  order      Int       @default(0)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  table      TableMeta @relation("TableViews", fields: [tableId], references: [id], onDelete: Cascade)

  @@unique([tableId, slug])
  @@index([tableId])
  @@index([tableId, order])
}


model Record {
  id          Int          @id @default(autoincrement())
  companyId   Int
  tableId     Int
  data        Json
  createdBy   Int?
  updatedBy   Int?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  attachments Attachment[]
  auditLogs   AuditLog[]
  creator     User?        @relation("CreatedBy", fields: [createdBy], references: [id])
  table       TableMeta    @relation("TableRecords", fields: [tableId], references: [id])
  company     Company      @relation(fields: [companyId], references: [id])
  
  statusDurations StatusDuration[]
  multiEventDurations MultiEventDuration[]
  
  @@index([companyId])
  @@index([tableId, companyId, createdAt(sort: Desc)]) // Composite index for table pagination
  @@index([tableId, companyId])                        // For record filtering
}

model Attachment {
  id         Int      @id @default(autoincrement())
  recordId   Int
  filename   String
  url        String
  size       Int
  uploadedBy Int
  uploadedAt DateTime @default(now())
  record     Record   @relation(fields: [recordId], references: [id])
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  recordId  Int?
  userId    Int?
  taskId    String?
  action    String
  diffJson  Json?
  timestamp DateTime @default(now())
  record    Record?  @relation(fields: [recordId], references: [id])
  user      User?    @relation(fields: [userId], references: [id])
}

model Task {
  id          String    @id @default(cuid())
  companyId   Int
  title       String
  description String?
  status      String
  assigneeId  Int?
  assignee    User?     @relation("TaskAssignee", fields: [assigneeId], references: [id])
  priority    String?
  dueDate     DateTime?
  tags        String[]
  duration_status_change String? // Legacy field, kept for safety or can be removed if fully migrated
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  statusDurations StatusDuration[]
  multiEventDurations MultiEventDuration[]
  taskSheetItems  TaskSheetItem[]
  company     Company   @relation(fields: [companyId], references: [id])
  
  @@index([companyId])
}

model CalendarEvent {
  id          String   @id @default(cuid())
  companyId   Int
  title       String
  description String?
  startTime   DateTime
  endTime     DateTime
  color       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  company     Company  @relation(fields: [companyId], references: [id])
  
  @@index([companyId])
}

model Client {
  id              Int                     @id @default(autoincrement())
  companyId       Int
  name            String
  email           String?
  phone           String?
  company         String?
  notes           String?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  oneTimePayments OneTimePayment[]
  paymentMethods  PaymentMethodInternal[]
  retainers       Retainer[]
  transactions    Transaction[]
  companyRelation Company                 @relation(fields: [companyId], references: [id])
  quotes          Quote[]
  tickets         Ticket[]
  financeRecords  FinanceRecord[]
  
  @@index([companyId])
}

model Retainer {
  id          Int       @id @default(autoincrement())
  clientId    Int
  title       String
  amount      Decimal   @db.Decimal(10, 2)
  frequency   String
  startDate   DateTime
  nextDueDate DateTime?
  status      String
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  client      Client    @relation(fields: [clientId], references: [id])
  
  @@index([clientId]) // Foreign key index for client lookups
}

model OneTimePayment {
  id        Int       @id @default(autoincrement())
  clientId  Int
  title     String
  amount    Decimal   @db.Decimal(10, 2)
  dueDate   DateTime
  paidDate  DateTime?
  status    String
  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  client    Client    @relation(fields: [clientId], references: [id])
  
  @@index([clientId]) // Foreign key index for client lookups
}

model Transaction {
  id          Int       @id @default(autoincrement())
  clientId    Int
  relatedType String
  relatedId   Int
  amount      Decimal   @db.Decimal(10, 2)
  attemptedBy Int?
  attemptDate DateTime  @default(now())
  paidDate    DateTime?
  status      String
  receiptFile String?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User?     @relation(fields: [attemptedBy], references: [id])
  client      Client    @relation(fields: [clientId], references: [id])
  
  @@index([clientId]) // Foreign key index for client lookups
}

model PaymentMethodInternal {
  id         Int      @id @default(autoincrement())
  clientId   Int
  methodType String
  details    String?
  note       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  client     Client   @relation(fields: [clientId], references: [id])
}

// NEW TABLE FOR DURATION TRACKING
model StatusDuration {
  id               Int            @id @default(autoincrement())
  
  automationRuleId Int
  automationRule   AutomationRule @relation(fields: [automationRuleId], references: [id], onDelete: Cascade)
  
  recordId         Int?
  record           Record?        @relation(fields: [recordId], references: [id], onDelete: Cascade)
  
  taskId           String?
  task             Task?          @relation(fields: [taskId], references: [id], onDelete: Cascade)

  durationSeconds  Int
  durationString   String // For display: "Xd Yh Zm Qs"
  
  fromValue        String?
  toValue          String?
  
  createdAt        DateTime       @default(now())
  
  @@index([automationRuleId])
  @@index([recordId])
}

// TABLE FOR MULTI-EVENT DURATION TRACKING
model MultiEventDuration {
  id               Int            @id @default(autoincrement())
  
  automationRuleId Int
  automationRule   AutomationRule @relation(fields: [automationRuleId], references: [id], onDelete: Cascade)
  
  recordId         Int?
  record           Record?        @relation(fields: [recordId], references: [id], onDelete: Cascade)
  
  taskId           String?
  task             Task?          @relation(fields: [taskId], references: [id], onDelete: Cascade)
  
  // Stores the event chain as JSON:
  // [{ eventName: "ליד נוצר", timestamp: "...", value: "..." }, ...]
  eventChain       Json
  
  // Stores the calculated deltas between events as JSON:
  // [{ from: "ליד נוצר", to: "בטיפול", durationSeconds: 3600, durationString: "1h" }, ...]
  eventDeltas      Json
  
  // Overall metrics
  totalDurationSeconds Int
  totalDurationString  String
  
  // Weighted metric (if applicable)
  weightedScore    Float?
  
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  
  @@index([automationRuleId])
  @@index([recordId])
  @@index([taskId])
}

model AnalyticsView {
  id          Int      @id @default(autoincrement())
  companyId   Int
  title       String
  type        String   // 'COUNT', 'AVERAGE', 'SUM', 'CONVERSION', 'DISTRIBUTION'
  description String?
  config      Json     // Stores: tableId, field, filter, groupBy, etc.
  order       Int      @default(0)
  color       String?  @default("bg-white")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  folderId    Int?
  folder      ViewFolder? @relation(fields: [folderId], references: [id])
  company     Company     @relation(fields: [companyId], references: [id])
  
  @@index([companyId])
}

model ViewFolder {
  id        Int      @id @default(autoincrement())
  companyId Int
  name      String
  type      String   @default("ANALYTICS") // "ANALYTICS" | "AUTOMATION"
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  analyticsViews AnalyticsView[]
  automationRules AutomationRule[]

  company        Company        @relation(fields: [companyId], references: [id])
  
  @@index([companyId])
}

model Workflow {
  id          Int             @id @default(autoincrement())
  companyId   Int
  name        String
  description String?
  color       String?         @default("blue")
  icon        String?         @default("GitBranch")
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  
  stages      WorkflowStage[]
  instances   WorkflowInstance[]
  company     Company         @relation(fields: [companyId], references: [id])

  @@index([companyId])
}

model WorkflowStage {
  id          Int      @id @default(autoincrement())
  workflowId  Int
  name        String
  description String?
  color       String?
  icon        String?
  order       Int      @default(0)
  
  details     Json?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  workflow    Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  instances   WorkflowInstance[] // Relation to instances currently at this stage

  @@index([workflowId])
}

model WorkflowInstance {
  id              Int      @id @default(autoincrement())
  companyId       Int
  workflowId      Int
  name            String   // Specific name for this execution (e.g. "Onboarding Client X")
  status          String   @default("active") // active, completed
  
  currentStageId  Int?
  currentStage    WorkflowStage? @relation(fields: [currentStageId], references: [id])
  
  creatorId       Int
  creator         User     @relation("InstanceCreator", fields: [creatorId], references: [id])
  
  assigneeId      Int?
  assignee        User?    @relation("InstanceAssignee", fields: [assigneeId], references: [id])
  
  completedStages Json     @default("[]") // Array of stage IDs that are done
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  workflow        Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  company         Company  @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@index([workflowId])
}

model Product {
  id          Int      @id @default(autoincrement())
  companyId   Int
  name        String
  description String?
  type        String   @default("SERVICE") // SERVICE, PRODUCT, PACKAGE
  price       Decimal  @db.Decimal(10, 2)
  cost        Decimal? @db.Decimal(10, 2)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  company     Company  @relation(fields: [companyId], references: [id])
  quoteItems  QuoteItem[]

  @@index([companyId])
}

model Quote {
  id          String   @id @default(cuid())
  companyId   Int
  quoteNumber Int?     // Incremental number per company (e.g., 00001, 00002)
  
  clientId        Int?
  clientName      String
  clientEmail     String?
  clientPhone     String?
  clientTaxId     String? // H.P.
  clientAddress   String?
  
  total           Decimal  @db.Decimal(10, 2)
  status          String   @default("DRAFT") // DRAFT, SENT, ACCEPTED, REJECTED
  isTrashed       Boolean  @default(false)   // Soft delete - move to trash
  
  validUntil      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company         Company  @relation(fields: [companyId], references: [id])
  client          Client?  @relation(fields: [clientId], references: [id])
  items           QuoteItem[]

  @@unique([companyId, quoteNumber]) // Ensure unique quote number per company
  @@index([companyId])
  @@index([companyId, isTrashed])
  @@index([companyId, isTrashed, createdAt(sort: Desc)]) // For listing non-trashed quotes
}

model QuoteItem {
  id        Int      @id @default(autoincrement())
  quoteId   String
  productId Int?
  
  description String
  quantity    Int      @default(1)
  unitPrice   Decimal  @db.Decimal(10, 2)
  unitCost    Decimal? @db.Decimal(10, 2)

  quote     Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  product   Product? @relation(fields: [productId], references: [id])
}

model Ticket {
  id          Int      @id @default(autoincrement())
  companyId   Int
  title       String
  description String?
  status      String   @default("OPEN") // OPEN, IN_PROGRESS, WAITING, RESOLVED, CLOSED
  priority    String   @default("MEDIUM") // LOW, MEDIUM, HIGH, CRITICAL
  type        String   @default("SERVICE") // SERVICE, COMPLAINT, RETENTION, OTHER
  
  clientId    Int?
  client      Client?  @relation(fields: [clientId], references: [id])
  
  assigneeId  Int?
  assignee    User?    @relation("TicketAssignee", fields: [assigneeId], references: [id])
  
  creatorId   Int
  creator     User     @relation("TicketCreator", fields: [creatorId], references: [id])
  
  tags        String[]
  
  slaDueDate          DateTime?  // Deadline for resolving the ticket
  slaResponseDueDate  DateTime?  // Deadline for first response (move to IN_PROGRESS)

  comments    TicketComment[]
  breaches    SlaBreach[]
  activityLogs TicketActivityLog[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  company     Company  @relation(fields: [companyId], references: [id])
  
  @@index([companyId])
  @@index([companyId, status])       // For filtering tickets by status
  @@index([clientId])
  @@index([assigneeId])
}

model TicketComment {
  id        Int      @id @default(autoincrement())
  ticketId  Int
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  
  content   String
  isInternal Boolean @default(false)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@index([ticketId, createdAt(sort: Desc)]) // For loading comments in order
}

// Tracks all changes made to tickets for audit trail
model TicketActivityLog {
  id        Int      @id @default(autoincrement())
  ticketId  Int
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  
  fieldName   String   // e.g., "status", "priority", "type", "assignee", "client"
  fieldLabel  String   // Hebrew label for display, e.g., "סטטוס", "עדיפות"
  oldValue    String?  // Previous value (as string)
  newValue    String?  // New value (as string)
  oldLabel    String?  // Hebrew label for old value
  newLabel    String?  // Hebrew label for new value
  
  createdAt DateTime @default(now())
  
  @@index([ticketId])
  @@index([userId])
  @@index([createdAt])
}

model SlaPolicy {
  id          Int      @id @default(autoincrement())
  companyId   Int
  name        String
  description String?
  priority    String   // Defines which priority this SLA applies to
  responseTimeMinutes Int // Target response time
  resolveTimeMinutes  Int // Target resolution time
  
  company     Company  @relation(fields: [companyId], references: [id])
  
  @@unique([companyId, priority])
}

model SlaBreach {
  id          Int      @id @default(autoincrement())
  companyId   Int
  ticketId    Int
  
  priority    String   // Priority at the time of breach
  slaDueDate  DateTime // Expected time that was missed
  breachType  String   @default("RESOLVE") // RESPONSE or RESOLVE
  breachedAt  DateTime @default(now())
  
  status      String   @default("PENDING") // PENDING, REVIEWED, ACKNOWLEDGED
  notes       String?
  
  ticket      Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  company     Company  @relation(fields: [companyId], references: [id])
  
  @@index([companyId])
  @@index([ticketId])
  @@index([breachedAt])
}

model Folder {
  id        Int      @id @default(autoincrement())
  companyId Int
  parentId  Int?
  name      String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  parent    Folder?  @relation("FolderHierarchy", fields: [parentId], references: [id])
  children  Folder[] @relation("FolderHierarchy")
  files     File[]
  company   Company  @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@index([parentId])
}

model File {
  id        Int      @id @default(autoincrement())
  companyId Int
  folderId  Int?

  name      String
  url       String
  key       String   
  size      Int      
  type      String   

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  folder    Folder?  @relation(fields: [folderId], references: [id])
  company   Company  @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@index([folderId])
}

// Goal Planning Module
model Goal {
  id          Int      @id @default(autoincrement())
  companyId   Int
  
  name        String                    // Goal name (e.g., "Monthly Sales Target")
  metricType  String                    // SALES, REVENUE, LEADS, TASKS, CLOSING_RATIO, RETAINERS, QUOTES
  targetType  String   @default("sum")  // 'count' (quantity) or 'sum' (monetary/value)
  targetValue Decimal  @db.Decimal(15, 2)
  
  // Flexible filters stored as JSON
  // Examples: { clientId: 5 }, { frequency: "MONTHLY" }, { status: "DONE" }
  filters     Json?    @default("{}")

  // Legacy fields (kept for safety until migration, but filters json replaces them)
  tableId     Int?
  productId   Int?
  
  // Time period
  periodType  String   @default("MONTHLY")  // MONTHLY, QUARTERLY, YEARLY, CUSTOM
  startDate   DateTime
  endDate     DateTime
  
  // Thresholds for alerts
  warningThreshold   Int @default(70)   // % - Alert when below this
  criticalThreshold  Int @default(50)   // % - Critical alert when below this
  
  isActive    Boolean  @default(true)
  isArchived  Boolean  @default(false)
  order       Int      @default(0)
  notes       String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  company     Company  @relation(fields: [companyId], references: [id])
  
  @@index([companyId])
  @@index([companyId, isActive, endDate]) // For listing active goals sorted by end date
  @@index([metricType])
  @@index([startDate, endDate])
  @@index([companyId, order]) // For sorting by custom order
}

// DEDICATED FINANCE MODULE
model FinanceRecord {
  id          Int      @id @default(autoincrement())
  companyId   Int
  
  title       String   // e.g. "Google Ads", "Consulting Fee"
  amount      Decimal  @db.Decimal(15, 2)
  type        String   // 'INCOME' | 'EXPENSE'
  category    String?  // 'Marketing', 'Office', 'Sales', 'Payroll'
  
  date        DateTime @default(now())
  status      String   @default("COMPLETED") // PENDING, COMPLETED, CANCELLED
  
  // Optional relations for context
  clientId    Int?
  
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company     Company  @relation(fields: [companyId], references: [id])
  client      Client?  @relation(fields: [clientId], references: [id])
  
  // Sync fields
  syncRuleId  Int?
  originId    String?  // ID of the original record to prevent duplicates
  syncRule    FinanceSyncRule? @relation(fields: [syncRuleId], references: [id])

  @@index([companyId])
  @@index([date])
  @@index([type])
  @@unique([syncRuleId, originId]) // Prevent duplicate imports from same rule
}

model FinanceSyncRule {
  id          Int      @id @default(autoincrement())
  companyId   Int
  name        String
  targetType  String   // 'INCOME' | 'EXPENSE'
  
  sourceType  String   // 'TABLE', 'TRANSACTIONS', 'RETAINERS'
  sourceId    Int?     // If TABLE, the tableId
  
  // Mapping config: { amountField: "key1", dateField: "key2", titleField: "key3", categoryValue: "Sales" }
  fieldMapping Json    
  
  lastRunAt   DateTime?
  isActive    Boolean  @default(true)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  company     Company  @relation(fields: [companyId], references: [id])
  records     FinanceRecord[]

  @@index([companyId])
}

model FixedExpense {
  id          Int      @id @default(autoincrement())
  companyId   Int
  
  title       String
  amount      Decimal  @db.Decimal(10, 2)
  frequency   String   // MONTHLY, YEARLY, WEEKLY, ONE_TIME
  payDay      Int?     // Day of month (1-31)
  
  category    String?
  description String?
  status      String   @default("ACTIVE") // ACTIVE, PAUSED
  startDate   DateTime @default(now())

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company     Company  @relation(fields: [companyId], references: [id])
  
  @@index([companyId])
}

// TASK SHEETS - Daily/Weekly Task Pages for Employees
model TaskSheet {
  id          Int      @id @default(autoincrement())
  companyId   Int
  
  title       String               // e.g., "Daily Tasks - Sales Team"
  description String?
  type        String   @default("DAILY") // DAILY, WEEKLY
  
  assigneeId  Int                  // The employee this sheet is assigned to
  assignee    User     @relation("TaskSheetAssignee", fields: [assigneeId], references: [id])
  
  createdById Int                  // Admin who created the sheet
  createdBy   User     @relation("TaskSheetCreator", fields: [createdById], references: [id])
  
  validFrom   DateTime @default(now())   // When this sheet becomes active
  validUntil  DateTime?                   // Optional expiration
  
  isActive    Boolean  @default(true)
  
  items       TaskSheetItem[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  company     Company  @relation(fields: [companyId], references: [id])
  
  @@index([companyId])
  @@index([assigneeId])
  @@index([createdById])
}

model TaskSheetItem {
  id          Int      @id @default(autoincrement())
  sheetId     Int
  
  title       String               // Task item title
  description String?
  
  priority    String   @default("NORMAL") // URGENT, HIGH, NORMAL, LOW, OPPORTUNITY
  category    String?              // Custom category like "דחוף", "הזדמנות", "ממתין"
  
  order       Int      @default(0) // Display order within the sheet
  
  isCompleted Boolean  @default(false)
  completedAt DateTime?
  
  dueTime     String?              // Optional time like "09:00" for daily tasks
  
  notes       String?              // Optional notes when completing
  
  // Link to existing task (optional)
  linkedTaskId String?
  linkedTask   Task?    @relation(fields: [linkedTaskId], references: [id], onDelete: SetNull)
  
  // Automation actions to run when item is completed
  // JSON format: [{ actionType: "UPDATE_RECORD" | "CREATE_TASK" | "CREATE_FINANCE" | "SEND_NOTIFICATION", config: {...} }]
  onCompleteActions Json?  @default("[]")
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  sheet       TaskSheet @relation(fields: [sheetId], references: [id], onDelete: Cascade)
  
  @@index([sheetId])
  @@index([linkedTaskId])
}

// ============================================
// WORKERS MODULE - Employee Management System
// ============================================

// Department - Organizational unit for grouping workers
model Department {
  id          Int      @id @default(autoincrement())
  companyId   Int
  
  name        String               // e.g., "Sales", "Marketing", "Development"
  description String?
  color       String?  @default("#3B82F6") // For visual identification
  icon        String?  @default("Building2")
  
  managerId   Int?                 // Optional department manager
  
  isActive    Boolean  @default(true)
  
  workers     Worker[]
  onboardingPaths OnboardingPath[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  company     Company  @relation(fields: [companyId], references: [id])
  
  @@index([companyId])
}

// Worker - Employee in the organization
model Worker {
  id          Int      @id @default(autoincrement())
  companyId   Int
  
  // Personal Info
  firstName   String
  lastName    String
  email       String?
  phone       String?
  avatar      String?              // Profile image URL
  
  // Employment Info
  departmentId Int
  department   Department @relation(fields: [departmentId], references: [id])
  
  position    String?              // Job title
  employeeId  String?              // Internal employee number
  
  startDate   DateTime  @default(now())
  endDate     DateTime?            // If employment ended
  
  status      String   @default("ONBOARDING") // ONBOARDING, ACTIVE, ON_LEAVE, TERMINATED
  
  // Optional link to system user
  linkedUserId Int?     @unique
  
  // Custom fields as JSON
  customFields Json?    @default("{}")
  
  notes       String?
  
  onboardingProgress WorkerOnboarding[]
  assignedTasks      WorkerTask[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  company     Company  @relation(fields: [companyId], references: [id])
  
  @@index([companyId])
  @@index([departmentId])
  @@index([status])
}

// OnboardingPath - Template for department-specific onboarding
model OnboardingPath {
  id          Int      @id @default(autoincrement())
  companyId   Int
  
  name        String               // e.g., "Sales Team Onboarding"
  description String?
  
  departmentId Int?                // Optional - specific to department
  department   Department? @relation(fields: [departmentId], references: [id])
  
  isDefault   Boolean  @default(false) // Default path for the department
  isActive    Boolean  @default(true)
  
  estimatedDays Int?               // Expected time to complete
  
  steps       OnboardingStep[]
  workerProgress WorkerOnboarding[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  company     Company  @relation(fields: [companyId], references: [id])
  
  @@index([companyId])
  @@index([departmentId])
}

// OnboardingStep - Individual step in an onboarding path
model OnboardingStep {
  id          Int      @id @default(autoincrement())
  pathId      Int
  
  title       String               // Step name
  description String?              // Detailed instructions
  
  type        String   @default("TASK") // TASK, TRAINING, DOCUMENT, MEETING, CHECKLIST
  
  order       Int      @default(0) // Display order
  
  estimatedMinutes Int?            // Expected time to complete
  
  // For TRAINING type - link to materials
  resourceUrl String?
  resourceType String?             // VIDEO, PDF, LINK, INTERNAL
  
  // Required dependencies (step IDs that must be completed first)
  requiresSteps Int[]  @default([])
  
  // Automation when completed
  onCompleteActions Json? @default("[]") // Similar to TaskSheet items
  
  isRequired  Boolean  @default(true)
  
  workerProgress WorkerOnboardingStep[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  path        OnboardingPath @relation(fields: [pathId], references: [id], onDelete: Cascade)
  
  @@index([pathId])
}

// WorkerOnboarding - Tracks a worker's progress through an onboarding path
model WorkerOnboarding {
  id          Int      @id @default(autoincrement())
  
  workerId    Int
  worker      Worker   @relation(fields: [workerId], references: [id], onDelete: Cascade)
  
  pathId      Int
  path        OnboardingPath @relation(fields: [pathId], references: [id])
  
  status      String   @default("IN_PROGRESS") // IN_PROGRESS, COMPLETED, PAUSED
  
  startedAt   DateTime @default(now())
  completedAt DateTime?
  
  stepProgress WorkerOnboardingStep[]
  
  notes       String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@unique([workerId, pathId])
  @@index([workerId])
  @@index([pathId])
}

// WorkerOnboardingStep - Tracks completion of individual steps
model WorkerOnboardingStep {
  id          Int      @id @default(autoincrement())
  
  onboardingId Int
  onboarding   WorkerOnboarding @relation(fields: [onboardingId], references: [id], onDelete: Cascade)
  
  stepId      Int
  step        OnboardingStep @relation(fields: [stepId], references: [id], onDelete: Cascade)
  
  status      String   @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED, SKIPPED
  
  completedAt DateTime?
  notes       String?
  
  // Score/feedback if it's a training step
  score       Int?
  feedback    String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@unique([onboardingId, stepId])
  @@index([onboardingId])
  @@index([stepId])
}

// WorkerTask - Tasks assigned to workers (separate from system Tasks)
model WorkerTask {
  id          Int      @id @default(autoincrement())
  companyId   Int
  
  workerId    Int
  worker      Worker   @relation(fields: [workerId], references: [id], onDelete: Cascade)
  
  title       String
  description String?
  
  priority    String   @default("NORMAL") // URGENT, HIGH, NORMAL, LOW
  status      String   @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED, CANCELLED
  
  dueDate     DateTime?
  completedAt DateTime?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  company     Company  @relation(fields: [companyId], references: [id])
  
  @@index([companyId])
  @@index([workerId])
}

// NURTURE HUB MODULE
model NurtureList {
  id          Int      @id @default(autoincrement())
  companyId   Int
  name        String   // e.g. "Birthday Club", "VIP Clients"
  slug        String   // e.g. "birthday-club"
  description String?

  subscribers NurtureSubscriber[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company     Company  @relation(fields: [companyId], references: [id])

  @@unique([companyId, slug])
  @@index([companyId])
}

model NurtureSubscriber {
  id            Int      @id @default(autoincrement())
  nurtureListId Int

  name          String
  email         String?
  phone         String?
  
  // Channel preferences - whether to send via each channel
  emailActive   Boolean  @default(true)
  phoneActive   Boolean  @default(true)

  // Metadata about where this came from
  sourceType    String?  // 'TABLE', 'MANUAL', 'IMPORT'
  sourceId      String?  // Record ID or similar
  sourceTableId Int?     // Table ID when sourceType is 'TABLE'

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  nurtureList   NurtureList @relation(fields: [nurtureListId], references: [id], onDelete: Cascade)

  @@index([nurtureListId])
  @@index([email])
  @@index([phone])
}

// Dashboard Widget Configuration - stores user's dashboard layout
model DashboardWidget {
  id          String   @id @default(cuid())
  userId      Int
  
  widgetType  String   // 'ANALYTICS' | 'TABLE'
  referenceId String   // ID of the analytics view or table view
  tableId     Int?     // Only for TABLE type widgets
  
  order       Int      @default(0)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([userId, order])
}
